# a2a-mcp-server environment variables
# Copy to .env and fill in your values

# ── AI Provider Keys ──────────────────────────────────────────────
# Claude API (tries SDK first, falls back to claude CLI OAuth)
ANTHROPIC_API_KEY=

# Gemini API (design-agent; tries SDK first, falls back to gemini CLI)
GOOGLE_API_KEY=
# Alternative name for Gemini key
# GEMINI_API_KEY=

# ── Server Configuration ─────────────────────────────────────────
# A2A orchestrator HTTP port (default: 8080)
# A2A_PORT=8080

# API key for non-loopback A2A callers (optional)
# A2A_API_KEY=

# ── Sandbox ──────────────────────────────────────────────────────
# Sandbox execution timeout in ms (default: 30000)
# A2A_SANDBOX_TIMEOUT=30000

# ── Response Limits ──────────────────────────────────────────────
# Max response size in chars (default: 25000)
# A2A_MAX_RESPONSE_SIZE=25000

# ── Obsidian Vault ───────────────────────────────────────────────
# Path to Obsidian vault for knowledge worker (default: ~/Documents/Obsidian/a2a-knowledge)
# OBSIDIAN_VAULT=/path/to/vault

# ── Web Agent ─────────────────────────────────────────────────────
# Max response body size in bytes (default: 10485760 = 10MB)
# A2A_MAX_RESPONSE_BYTES=10485760

# Outbound fetch/API rate limit in requests per minute (0 = unlimited)
# A2A_WEB_RATE_LIMIT=0

# ── AI Agent ─────────────────────────────────────────────────────
# Max tokens for ask_claude responses (default: 4096)
# A2A_ASK_CLAUDE_MAX_TOKENS=4096

# ── Logging ──────────────────────────────────────────────────────
# Minimum log level: debug, info, warn, error (default: info)
# A2A_LOG_LEVEL=info

# ── Worker Timeouts (overrides config.json) ──────────────────────
# HTTP fetch timeout in ms (default: 30000)
# A2A_FETCH_TIMEOUT=30000
# Codex CLI timeout in ms (default: 120000)
# A2A_CODEX_TIMEOUT=120000
