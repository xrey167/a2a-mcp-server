{
  "name": "a2a-mcp-server",
  "version": "0.1.0",
  "description": "Multi-agent orchestrator bridging MCP (Model Context Protocol) and A2A (Agent-to-Agent) protocols. Connect AI agents to AI assistants.",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "a2a-mcp-server": "src/cli.ts"
  },
  "scripts": {
    "start": "bun src/server.ts",
    "start:acp": "bun src/acp-server.ts",
    "dev": "bun --watch src/server.ts",
    "init": "bun src/cli.ts init",
    "workers": "bun src/cli.ts workers",
    "test": "bun test",
    "prepublishOnly": "bun test"
  },
  "files": [
    "src/**/*.ts",
    "!src/__tests__/**",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "a2a",
    "agent",
    "multi-agent",
    "orchestrator",
    "claude",
    "ai",
    "model-context-protocol",
    "agent-to-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xrey167/a2a-mcp-server"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.7.4",
    "zod": "^4.3.6"
  }
}
